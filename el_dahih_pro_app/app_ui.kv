#:kivy 2.3
#:import get_color_from_hex kivy.utils.get_color_from_hex

<LoginScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: self.theme_cls.bg_normal

        # Top Header with Gradient Effect
        MDRelativeLayout:
            size_hint_y: 0.45
            canvas.before:
                Color:
                    rgba: get_color_from_hex("#00A8E8") if app.theme_cls.theme_style == "Light" else get_color_from_hex("#0D47A1")
                RoundedRectangle:
                    size: self.size
                    pos: self.pos
                    radius: [0, 0, 60, 60]
            
            MDBoxLayout:
                orientation: 'vertical'
                adaptive_height: True
                pos_hint: {"center_x": .5, "center_y": .55}
                spacing: "20dp"
                padding: "20dp"
                
                # Logo Icon
                MDIcon:
                    icon: "school"
                    font_size: "95sp"
                    pos_hint: {"center_x": .5}
                    theme_text_color: "Custom"
                    text_color: get_color_from_hex("#FFD700")
                    size_hint_y: None
                    height: "100dp"

                # Title
                MDLabel:
                    text: app.get_text('login_title')
                    font_style: "H3"
                    font_name: "Arabic"
                    halign: "center"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1
                    size_hint_y: None
                    height: "50dp"

                # Subtitle
                MDLabel:
                    text: app.get_text('login_subtitle')
                    font_name: "Arabic"
                    font_style: "Subtitle1"
                    halign: "center"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 0.85
                    size_hint_y: None
                    height: "30dp"

        # Login Form Container
        MDScrollView:
            MDBoxLayout:
                orientation: 'vertical'
                padding: ["30dp", "35dp", "30dp", "20dp"]
                spacing: "20dp"
                adaptive_height: True
                
                # Student Code Input
                MDTextField:
                    id: user_code
                    hint_text: app.get_text('student_code')
                    mode: "rectangle"
                    fill_color_normal: get_color_from_hex("#F5F9FD") if app.theme_cls.theme_style == "Light" else get_color_from_hex("#1E1E1E")
                    icon_right: "account-circle-outline"
                    icon_right_color_normal: get_color_from_hex("#00A8E8")
                    font_name_hint_text: "Arabic"
                    halign: "right" if app.current_lang == 'ar' else "left"
                    size_hint_x: 1
                    multiline: False
                
                # Password Input
                MDTextField:
                    id: password
                    hint_text: app.get_text('password')
                    mode: "rectangle"
                    fill_color_normal: get_color_from_hex("#F5F9FD") if app.theme_cls.theme_style == "Light" else get_color_from_hex("#1E1E1E")
                    icon_right: "lock-outline"
                    icon_right_color_normal: get_color_from_hex("#00A8E8")
                    password: True
                    font_name_hint_text: "Arabic"
                    halign: "right" if app.current_lang == 'ar' else "left"
                    size_hint_x: 1
                    multiline: False

                # Button Container
                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_height: True
                    spacing: "15dp"
                    padding: [0, "20dp", 0, 0]

                    # Login Button
                    MDFillRoundFlatButton:
                        text: app.get_text('login_btn')
                        font_name: "Arabic"
                        font_size: "18sp"
                        size_hint_x: 1
                        height: "50dp"
                        md_bg_color: get_color_from_hex("#00A8E8")
                        text_color: 1, 1, 1, 1
                        elevation: 5
                        on_release: root.do_login(user_code.text, password.text)

                    # Language Toggle Button
                    MDTextButton:
                        text: app.get_text('menu_lang_en') if app.current_lang == 'ar' else app.get_text('menu_lang_ar')
                        font_name: "Arabic"
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex("#00A8E8")
                        size_hint_x: 1
                        on_release: app.change_language('en' if app.current_lang == 'ar' else 'ar')

        # Footer
        MDBoxLayout:
            size_hint_y: None
            height: "50dp"
            padding: ["10dp", "0dp", "10dp", "10dp"]
            
            MDLabel:
                text: app.get_text('footer_version')
                halign: "center"
                font_style: "Caption"
                theme_text_color: "Hint"
                font_name: "Arabic"


<DashboardScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: self.theme_cls.bg_normal

        # Top App Bar
        MDTopAppBar:
            title: app.get_text('dashboard_title')
            font_style: "H6"
            font_name: "Arabic"
            elevation: 4
            md_bg_color: get_color_from_hex("#00A8E8") if app.theme_cls.theme_style == "Light" else get_color_from_hex("#0D47A1")
            right_action_items: [["dots-vertical", lambda x: app.show_settings_menu(x)], ["logout", lambda x: app.logout_user()]]

        # Main Content
        MDScrollView:
            MDBoxLayout:
                orientation: 'vertical'
                padding: "20dp"
                spacing: "20dp"
                adaptive_height: True

                # Welcome Card
                MDCard:
                    size_hint_y: None
                    height: "120dp"
                    padding: "20dp"
                    radius: "15dp"
                    elevation: 4
                    md_bg_color: get_color_from_hex("#FFD700")
                    
                    MDRelativeLayout:
                        MDBoxLayout:
                            orientation: 'vertical'
                            spacing: "5dp"
                            pos_hint: {"center_y": .5}
                            
                            MDLabel:
                                text: app.get_text('welcome_msg')
                                font_name: "Arabic"
                                font_style: "H6"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 0.1, 0.1, 0.1, 1
                                size_hint_y: None
                                height: "30dp"
                            
                            MDLabel:
                                text: app.get_text('welcome_sub')
                                font_name: "Arabic"
                                font_style: "Caption"
                                theme_text_color: "Custom"
                                text_color: 0.2, 0.2, 0.2, 1
                                size_hint_y: None
                                height: "25dp"
                        
                        MDIcon:
                            icon: "crown"
                            font_size: "50sp"
                            pos_hint: {"right": 1, "center_y": .5}
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 0.8

                # Courses Section
                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_height: True
                    spacing: "12dp"

                    MDLabel:
                        id: section_title
                        text: app.get_text('courses_header')
                        font_name: "Arabic"
                        font_style: "Subtitle1"
                        bold: True
                        adaptive_height: True
                        theme_text_color: "Custom"
                        text_color: get_color_from_hex("#00A8E8")
                        size_hint_y: None
                        height: "30dp"

                    MDList:
                        id: courses_list
                        spacing: "12dp"
                        adaptive_height: True
